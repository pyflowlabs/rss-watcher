# Copy this file to ".env" and fill in your real values.
# The .env file is excluded by .gitignore and will NOT be pushed to GitHub.

# Required: the RSS feed to watch
FEED_URL=https://feeds.bbci.co.uk/news/rss.xml

# Required: your Discord webhook URL
# (Discord: Server Settings -> Integrations -> Webhooks -> New Webhook -> copy URL)
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/xxxxxxxx/yyyyyyyy

# Optional: check interval in loop mode, in seconds (default: 900 = 15 min)
POLL_INTERVAL=900

# Optional: max number of entries reported on the very first run (default: 3)
MAX_FIRST_RUN=3
